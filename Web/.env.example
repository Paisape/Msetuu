# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
BASEPATH=
NEXT_PUBLIC_APP_URL=http://localhost:3000${BASEPATH}
NEXT_PUBLIC_DOCS_URL=https://demos.pixinvent.com/vuexy-nextjs-admin-template/documentation

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_BASEPATH=${BASEPATH}/api/auth
NEXTAUTH_URL=http://localhost:3000${BASEPATH}/api/auth
NEXTAUTH_SECRET=

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_URL=http://localhost:3000${BASEPATH}/api
NEXT_PUBLIC_API_URL=${API_URL}

# -----------------------------------------------------------------------------
# Mapbox
# -----------------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Astrology. These are fallback defaults only; Config > Astrology in the admin panel can
# override them without a restart.
# Panchang / Choghadiya / Muhurat — free key: sign up at https://freeastrologyapi.com/signup
# Rashifal (daily/monthly horoscope text) — sign up at https://www.astrologyapi.com (50 free
# credits, then pay-as-you-go)
# -----------------------------------------------------------------------------
ASTROLOGY_API_KEY=
ASTROLOGYAPI_USER_ID=
ASTROLOGYAPI_API_KEY=

# -----------------------------------------------------------------------------
# Email (SMTP). Used for every customer email — order confirmations, payment receipts,
# video-ready notices, Yatra confirmations, secure-config OTPs, etc. These are fallback
# defaults only; Config > Email in the admin panel can override them without a restart
# once SETTINGS_ENCRYPTION_KEY below is set.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Settings encryption — encrypts Razorpay/SMTP/SMS secrets stored via Config > PG/Email/SMS.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
SETTINGS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Secure Config menu (admin sidebar > Config) — a second password gating Payment Gateway /
# Email / SMS secrets, separate from the admin's own login. Only used once, to bootstrap the
# database row the first time the menu is opened; change it from the Config menu afterward.
# -----------------------------------------------------------------------------
SECURE_CONFIG_INITIAL_PASSWORD=
SECURE_CONFIG_OTP_EMAIL=

# -----------------------------------------------------------------------------
# Google Drive API (Operation > Video Upload — Folder mode)
# Create a key at https://console.cloud.google.com/apis/credentials, enable the
# "Google Drive API" on the project, and restrict the key to that API. The Drive folder you
# scan must be shared as "Anyone with the link" (Viewer) for this key to read it.
# -----------------------------------------------------------------------------
GOOGLE_DRIVE_API_KEY=

# -----------------------------------------------------------------------------
# Razorpay (sandbox/test mode) — get real test keys from the Razorpay Dashboard
# (Settings > API Keys > Generate Test Key). Payments are rejected with a 503 until both
# of these are set to real values — there is no mock/simulated fallback.
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
